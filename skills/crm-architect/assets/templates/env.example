# =============================================================================
# crm-architect — environment / secrets template
# Public Firebase web config is safe in the client (security = rules + claims).
# SECRETS below are SERVER-SIDE only: set via `firebase functions:secrets:set NAME`
# or Secret Manager. NEVER commit real values or ship them to the browser.
# =============================================================================

# ---- Firebase web config (client, public) ----
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_RTDB_URL=https://your-project-default-rtdb.firebaseio.com

# ---- AI (Cloud Functions secret) ----
LLM_API_KEY=                      # Anthropic Claude API key (server-side only)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5

# ---- Email ----
RESEND_API_KEY=                   # or SENDGRID_API_KEY / MAILGUN_API_KEY
EMAIL_FROM="CRM <no-reply@yourdomain.com>"
GOOGLE_OAUTH_CLIENT_ID=           # Gmail/Calendar sync
GOOGLE_OAUTH_CLIENT_SECRET=
MS_GRAPH_CLIENT_ID=               # Outlook/Graph
MS_GRAPH_CLIENT_SECRET=

# ---- WhatsApp Business Cloud API ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=            # webhook verification
WHATSAPP_APP_SECRET=             # signature verification

# ---- Telephony / SMS (Twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Payments ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# WOMPI_PRIVATE_KEY=             # Colombia
# WOMPI_EVENTS_SECRET=

# ---- E-signature ----
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET=

# ---- Search ----
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=               # server-side; client uses a search-only key
ALGOLIA_SEARCH_KEY=

# ---- Deploy (GitHub Actions) ----
FIREBASE_TOKEN=                  # or use a service-account JSON via GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT=        # JSON (set as a GitHub secret)
